{
  "name": "brand-intent",
  "version": "0.4.4",
  "description": "An open file format specification for making brand intent machine-readable.",
  "author": "Christophe Stoll <christophe@stoll.studio>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/studiostoll/brand-intent.git"
  },
  "homepage": "https://intent.stoll.studio",
  "bin": {
    "brand-intent": "./cli/index.mjs"
  },
  "exports": {
    ".": {
      "types": "./parser/index.ts",
      "default": "./parser/index.ts"
    },
    "./parser": {
      "types": "./parser/index.ts",
      "default": "./parser/index.ts"
    },
    "./package.json": "./package.json"
  },
  "types": "./parser/index.ts",
  "keywords": [
    "brand",
    "design-tokens",
    "ai",
    "specification",
    "brand-identity",
    "design-system"
  ],
  "scripts": {
    "release": "./scripts/release.sh"
  },
  "files": [
    "cli/",
    "parser/",
    "skills/",
    "examples/"
  ]
}
