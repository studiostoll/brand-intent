{
  "name": "brand-intent-lang",
  "displayName": "Brand Intent — .identity, .brand, .format, .purpose, .composition",
  "description": "Syntax highlighting and autocomplete for the Brand Intent specification — .identity, .brand, .format, .purpose, and .composition files that define brand identity, visual language, and content architecture.",
  "version": "0.9.0",
  "publisher": "studiostoll",
  "author": {
    "name": "Studio Stoll",
    "url": "https://stoll.studio"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/studiostoll/brand-intent.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:brand-intent-identity",
    "onLanguage:brand-intent-brand",
    "onLanguage:brand-intent-format",
    "onLanguage:brand-intent-purpose",
    "onLanguage:brand-intent-composition"
  ],
  "contributes": {
    "languages": [
      {
        "id": "brand-intent-identity",
        "aliases": [
          "Brand Intent Identity"
        ],
        "extensions": [
          ".identity"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "brand-intent-brand",
        "aliases": [
          "Brand Intent Brand"
        ],
        "extensions": [
          ".brand"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "brand-intent-format",
        "aliases": [
          "Brand Intent Format"
        ],
        "extensions": [
          ".format"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "brand-intent-purpose",
        "aliases": [
          "Brand Intent Purpose"
        ],
        "extensions": [
          ".purpose"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "brand-intent-composition",
        "aliases": [
          "Brand Intent Composition"
        ],
        "extensions": [
          ".composition"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "brand-intent-identity",
        "scopeName": "source.brand-intent-identity",
        "path": "./syntaxes/identity.tmLanguage.json"
      },
      {
        "language": "brand-intent-brand",
        "scopeName": "source.brand-intent-brand",
        "path": "./syntaxes/brand.tmLanguage.json"
      },
      {
        "language": "brand-intent-format",
        "scopeName": "source.brand-intent-format",
        "path": "./syntaxes/format.tmLanguage.json"
      },
      {
        "language": "brand-intent-purpose",
        "scopeName": "source.brand-intent-purpose",
        "path": "./syntaxes/purpose.tmLanguage.json"
      },
      {
        "language": "brand-intent-composition",
        "scopeName": "source.brand-intent-composition",
        "path": "./syntaxes/composition.tmLanguage.json"
      }
    ]
  }
}
