{
  "scopeName": "source.brand-intent-brand",
  "name": "Brand Intent Brand",
  "patterns": [
    { "include": "#comment" },
    { "include": "#id-field" },
    { "include": "#name-field" },
    { "include": "#tokens-enum" },
    { "include": "#brand-colors-header" },
    { "include": "#state-colors-header" },
    { "include": "#color-bounds-header" },
    { "include": "#color-mode-enum" },
    { "include": "#color-strategy-enum" },
    { "include": "#color-adherence-enum" },
    { "include": "#state-colors-entry" },
    { "include": "#color-bounds-entry" },
    { "include": "#color-adherence-override" },
    { "include": "#color-group-header" },
    { "include": "#color-group-property" },
    { "include": "#color-group-entry" },
    { "include": "#color-group-reference" },
    { "include": "#color-group-entry-property" },
    { "include": "#theme-header" },
    { "include": "#brand-color-entry" },
    { "include": "#brand-color-print-sub" },
    { "include": "#token-slot-ref" },
    { "include": "#token-slot-with-comment" },
    { "include": "#token-slot" },
    { "include": "#spacing-value" },
    { "include": "#divider-header" },
    { "include": "#divider-value" },
    { "include": "#font-header" },
    { "include": "#font-value" },
    { "include": "#typography-header" },
    { "include": "#typography-value" },
    { "include": "#asset-header" },
    { "include": "#asset-value" },
    { "include": "#badge-header" },
    { "include": "#badge-value" },
    { "include": "#string-field" },
    { "include": "#keyword-partial" }
  ],
  "repository": {
    "comment": {
      "match": "^\\s*#.*$",
      "name": "comment.line.number-sign.brand-intent-brand"
    },
    "id-field": {
      "match": "^(id:)\\s+(.*)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" },
        "2": { "name": "entity.name.type.brand-intent-brand" }
      }
    },
    "name-field": {
      "match": "^(name:)\\s+(.*)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" },
        "2": { "name": "string.unquoted.brand-intent-brand" }
      }
    },
    "tokens-enum": {
      "match": "^(tokens:)\\s+(figma|inline)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" },
        "2": { "name": "entity.name.tag.brand-intent-brand" }
      }
    },
    "brand-colors-header": {
      "match": "^(brand-colors)\\s*$",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" }
      }
    },
    "state-colors-header": {
      "match": "^(state-colors)\\s*$",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" }
      }
    },
    "color-bounds-header": {
      "match": "^(color-bounds)\\s*$",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" }
      }
    },
    "color-mode-enum": {
      "match": "^(color-mode:)\\s+(static|dynamic|guided)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" },
        "2": { "name": "entity.name.tag.brand-intent-brand" }
      }
    },
    "color-strategy-enum": {
      "match": "^(color-strategy:)\\s+(monochrome|duotone|tricolor|spectrum)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" },
        "2": { "name": "entity.name.tag.brand-intent-brand" }
      }
    },
    "color-adherence-enum": {
      "match": "^(color-adherence:)\\s+(strict|on-brand|flexible)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" },
        "2": { "name": "entity.name.tag.brand-intent-brand" }
      }
    },
    "state-colors-entry": {
      "comment": "Indented entries under state-colors: problem/warning/success/info/inactive → hex",
      "match": "^(\\s{2,})(problem|warning|success|info|inactive)(:\\s*)(#[0-9A-Fa-f]{3,8})\\s*$",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "constant.other.color.rgb-value.brand-intent-brand" }
      }
    },
    "color-bounds-entry": {
      "comment": "Indented entries under color-bounds: light/dark (0–1) + saturation-floor (0–100)",
      "match": "^(\\s{2,})(light|dark|saturation-floor)(:\\s*)(\\S+)",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "constant.numeric.brand-intent-brand" }
      }
    },
    "color-adherence-override": {
      "comment": "Optional tolerance overrides under color-adherence: hue-tolerance / sat-tolerance",
      "match": "^(\\s{2,})(hue-tolerance|sat-tolerance)(:\\s*)(\\S+)",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "constant.numeric.brand-intent-brand" }
      }
    },
    "color-group-header": {
      "comment": "Grouped brand-colors: 2-space indent, bare group keyword",
      "match": "^( {2})(primary|secondary|accent|neutral)\\s*$",
      "captures": {
        "2": { "name": "keyword.control.brand-intent-brand" }
      }
    },
    "color-group-property": {
      "comment": "Group-level property (4-space indent): meaning / distribution. distribution's value is numeric (0–100).",
      "match": "^( {4})(distribution)(:\\s*)(\\d+(?:\\.\\d+)?%?)\\s*$|^( {4})(meaning)(:\\s*)(.*)$",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "constant.numeric.brand-intent-brand" },
        "6": { "name": "support.type.property-name.brand-intent-brand" },
        "7": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "8": { "name": "string.unquoted.brand-intent-brand" }
      }
    },
    "color-group-entry": {
      "comment": "Color entry header inside a group: 4-space indent, #HEX  Name",
      "match": "^( {4})(#[0-9A-Fa-f]{3,8})\\s+(.+?)\\s*$",
      "captures": {
        "2": { "name": "constant.other.color.rgb-value.brand-intent-brand" },
        "3": { "name": "entity.name.type.brand-intent-brand" }
      }
    },
    "color-group-reference": {
      "comment": "Layer 2 cross-group reference: $group.role",
      "match": "^( {4})(\\$[a-z]+\\.[a-z-]+)\\s*$",
      "captures": {
        "2": { "name": "entity.name.tag.brand-intent-brand" }
      }
    },
    "color-group-entry-property": {
      "comment": "Per-entry sub-property: 6-space indent, role / meaning / pantone / hks / cmyk",
      "match": "^( {6})(role|meaning|pantone|hks|cmyk)(:\\s*)(.*)$",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "string.unquoted.brand-intent-brand" }
      }
    },
    "theme-header": {
      "match": "^(theme)\\s+(\\S+)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" },
        "2": { "name": "entity.name.type.brand-intent-brand" }
      }
    },
    "brand-color-entry": {
      "comment": "Top-level brand color: exactly 2-space indent, name: #HEX",
      "match": "^( {2})([-\\w]+)(:\\s*)(#[0-9A-Fa-f]{3,8})\\s*$",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "constant.other.color.rgb-value.brand-intent-brand" }
      }
    },
    "brand-color-print-sub": {
      "comment": "Print sub-keys under a brand color: 4-space indent, pantone/hks/cmyk",
      "match": "^( {4})(pantone|hks|cmyk)(:\\s*)(\\S.*)",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "constant.numeric.brand-intent-brand" }
      }
    },
    "token-slot-ref": {
      "comment": "Indented token slot with $ref value, optional alpha suffix",
      "match": "^(\\s{2,})([-\\w]+)(:\\s*)(\\$[\\w-]+)(?:\\s+([0-9]+(?:\\.[0-9]+)?%))?",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "entity.name.tag.brand-intent-brand" },
        "5": { "name": "constant.numeric.brand-intent-brand" }
      }
    },
    "token-slot-with-comment": {
      "comment": "Indented token slot: background: #HEX (optional NN%) (optional # annotation)",
      "match": "^(\\s{2,})([-\\w]+)(:\\s*)(#[0-9A-Fa-f]{3,8})(?:\\s+([0-9]+(?:\\.[0-9]+)?%))?(\\s+#.*)?$",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "constant.other.color.rgb-value.brand-intent-brand" },
        "5": { "name": "constant.numeric.brand-intent-brand" },
        "6": { "name": "comment.line.number-sign.brand-intent-brand" }
      }
    },
    "token-slot": {
      "comment": "Indented token slot without comment, optional alpha suffix",
      "match": "^(\\s{2,})([-\\w]+)(:\\s*)(#[0-9A-Fa-f]{3,8})(?:\\s+([0-9]+(?:\\.[0-9]+)?%))?\\s*$",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "constant.other.color.rgb-value.brand-intent-brand" },
        "5": { "name": "constant.numeric.brand-intent-brand" }
      }
    },
    "spacing-value": {
      "comment": "Indented spacing key-value pairs",
      "match": "^(\\s{2,})(unit|xs|s|m|l|xl)(:\\s*)(\\S+)",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "constant.numeric.brand-intent-brand" }
      }
    },
    "divider-header": {
      "match": "^(divider)\\s+(\\S+)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" },
        "2": { "name": "entity.name.type.brand-intent-brand" }
      }
    },
    "divider-value": {
      "comment": "Indented divider property key-value pairs (color removed in 0.6.0 — sourced from theme)",
      "match": "^(\\s{2,})(thickness|width|spacing|align)(:\\s*)(\\S+)",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "constant.numeric.brand-intent-brand" }
      }
    },
    "font-header": {
      "match": "^(font)\\s+(\\S+)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" },
        "2": { "name": "entity.name.type.brand-intent-brand" }
      }
    },
    "font-value": {
      "comment": "Indented font block properties",
      "match": "^(\\s{2,})(name|fallback|source|variable|variable-italic|static-\\d{3}i?)(:\\s*)(\\S+)",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "string.unquoted.brand-intent-brand" }
      }
    },
    "typography-header": {
      "match": "^(typography)\\s+(\\S+)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" },
        "2": { "name": "entity.name.type.brand-intent-brand" }
      }
    },
    "typography-value": {
      "comment": "Indented typography block properties; font ref colored teal as a cross-reference",
      "match": "^(\\s{2,})(font)(:\\s*)(\\$[\\w]+)|^(\\s{2,})(weight|strong|size|opsz|lineHeight|letterSpacing|autofit-min|autofit-max)(:\\s*)(\\S+)|^(\\s{2,})(italic|uppercase)\\s*$",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "entity.name.tag.brand-intent-brand" },
        "6": { "name": "support.type.property-name.brand-intent-brand" },
        "7": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "8": { "name": "constant.numeric.brand-intent-brand" },
        "10": { "name": "support.type.property-name.brand-intent-brand" }
      }
    },
    "asset-header": {
      "match": "^(logo|photo|video|illustration)\\s+(\\S+)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" },
        "2": { "name": "entity.name.type.brand-intent-brand" }
      }
    },
    "asset-value": {
      "match": "^(\\s{2,})(label|src|lottie|gltf|generator)(:\\s*)(.*)|^(\\s{2,})(aspect|scale)(:\\s*)(\\S+)|^(\\s{2,})(animated|generator-params)\\s*$|^(\\s{2,})(loop)(?:(:\\s*)(true|false))?\\s*$",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "string.unquoted.brand-intent-brand" },
        "6": { "name": "support.type.property-name.brand-intent-brand" },
        "7": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "8": { "name": "constant.numeric.brand-intent-brand" },
        "10": { "name": "support.type.property-name.brand-intent-brand" },
        "12": { "name": "support.type.property-name.brand-intent-brand" },
        "13": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "14": { "name": "constant.language.boolean.brand-intent-brand" }
      }
    },
    "badge-header": {
      "comment": "Bare `label:` or `cta:` line that introduces a badge style block.",
      "match": "^(label|cta):\\s*$",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" }
      }
    },
    "badge-value": {
      "comment": "Indented badge style properties: padding (CSS shorthand) + radius",
      "match": "^(\\s{2,})(padding|radius)(:\\s*)(.+)$",
      "captures": {
        "2": { "name": "support.type.property-name.brand-intent-brand" },
        "3": { "name": "punctuation.separator.key-value.brand-intent-brand" },
        "4": { "name": "constant.numeric.brand-intent-brand" }
      }
    },
    "string-field": {
      "match": "^(language|locale|domain|app-icon|favicon|og-image|figma-file-key|figma-collection|tokens-file|spacing):?\\s*(.+)?",
      "captures": {
        "1": { "name": "support.type.property-name.brand-intent-brand" },
        "2": { "name": "string.unquoted.brand-intent-brand" }
      }
    },
    "keyword-partial": {
      "comment": "Fallback: color the keyword token on incomplete lines (while typing)",
      "match": "^(id:|name:|language:|locale:|domain:|app-icon:|favicon:|og-image:|tokens:|figma-file-key:|figma-collection:|tokens-file:|spacing:|label:|cta:|color-mode:|color-strategy:|color-adherence:|brand-colors|state-colors|color-bounds|theme|divider|font|typography|logo|photo|video|illustration)(?=\\s|$)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-brand" }
      }
    }
  }
}
