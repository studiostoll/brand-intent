{
  "scopeName": "source.brand-intent-format",
  "name": "Brand Intent Format",
  "patterns": [
    { "include": "#comment" },
    { "include": "#id-field" },
    { "include": "#name-field" },
    { "include": "#category" },
    { "include": "#no" },
    { "include": "#purposes" },
    { "include": "#size" },
    { "include": "#grid" },
    { "include": "#numeric-field" },
    { "include": "#insets" },
    { "include": "#string-field" },
    { "include": "#keyword-partial" }
  ],
  "repository": {
    "comment": {
      "match": "^\\s*#.*$",
      "name": "comment.line.number-sign.brand-intent-format"
    },
    "id-field": {
      "match": "^(id:)\\s+(.*)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-format" },
        "2": { "name": "entity.name.type.brand-intent-format" }
      }
    },
    "name-field": {
      "match": "^(name:)\\s+(.*)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-format" },
        "2": { "name": "string.unquoted.brand-intent-format" }
      }
    },
    "category": {
      "match": "^(category:)\\s+(instagram|linkedin|print|signage)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-format" },
        "2": { "name": "entity.name.tag.brand-intent-format" }
      }
    },
    "no": {
      "match": "^(no:)\\s+(.*)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-format" },
        "2": { "name": "string.unquoted.brand-intent-format" }
      }
    },
    "purposes": {
      "match": "^(purposes:)\\s+(.*)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-format" },
        "2": { "name": "string.unquoted.brand-intent-format" }
      }
    },
    "size": {
      "match": "^(size:)\\s+(\\S+)\\s+(\\S+)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-format" },
        "2": { "name": "constant.numeric.brand-intent-format" },
        "3": { "name": "constant.numeric.brand-intent-format" }
      }
    },
    "grid": {
      "match": "^(grid:)\\s+(\\d+)\\s+(\\d+)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-format" },
        "2": { "name": "constant.numeric.brand-intent-format" },
        "3": { "name": "constant.numeric.brand-intent-format" }
      }
    },
    "numeric-field": {
      "match": "^(dpi|bleed|comfort):\\s*(.+)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-format" },
        "2": { "name": "constant.numeric.brand-intent-format" }
      }
    },
    "insets": {
      "match": "^(danger:|crop:)\\s+(.*)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-format" },
        "2": { "name": "constant.numeric.brand-intent-format" }
      }
    },
    "string-field": {
      "match": "^(label|sublabel):\\s*(.+)",
      "captures": {
        "1": { "name": "support.type.property-name.brand-intent-format" },
        "2": { "name": "string.unquoted.brand-intent-format" }
      }
    },
    "keyword-partial": {
      "comment": "Fallback: color the keyword token on incomplete lines (while typing)",
      "match": "^(id:|name:|category:|no:|purposes:|size:|grid:|dpi:|bleed:|comfort:|danger:|crop:|label:|sublabel:)(?=\\s|$)",
      "captures": {
        "1": { "name": "keyword.control.brand-intent-format" }
      }
    }
  }
}
