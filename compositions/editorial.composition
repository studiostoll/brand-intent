# editorial.composition — grid mode
# Secondary above primary (newspaper style).
# Label badge top-right, info bottom-left, CTA bottom-right.
# This file contains zero brand-specific information.

id:    editorial
mode:  grid
image: full
logo:  top left

label      row 1  cols 3--4  right
secondary  row 2  cols 1--4  left center
primary    row 3  cols 1--4  left
meta       row 5  cols 1--3  left bottom
cta        row 5  cols 4--4  right bottom
